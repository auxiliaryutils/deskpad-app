# Copy to keystore.properties (gitignored) and fill in to enable signed release builds.
# Generate a keystore with:
#   keytool -genkeypair -v -keystore deskpad-release.jks -alias deskpad \
#     -keyalg RSA -keysize 2048 -validity 10000
storeFile=deskpad-release.jks
storePassword=your-store-password
keyAlias=deskpad
keyPassword=your-key-password
